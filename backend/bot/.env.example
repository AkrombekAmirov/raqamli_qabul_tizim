# Telegram
BOT_TOKEN=123456:REPLACE_WITH_TOKEN_FROM_BOTFATHER
# Admin guruh yoki kanal ID (manfiy son, masalan -1001234567890)
ADMIN_GROUP_ID=-1001234567890
# Vergul bilan ajratilgan admin foydalanuvchi ID lari (birinchisi super admin)
ADMIN_IDS=11111111,22222222

# Ma'lumotlar bazasi (compose ichki tarmog'i orqali)
POSTGRES_DB=turnikedb
POSTGRES_USER=turnikeuser
POSTGRES_PASSWORD=StrongSecurePass123!
DB_HOST=db
DB_PORT=5432

# Redis (FSM storage)
REDIS_HOST=redis
REDIS_PORT=6379

# Ollama AI (local LLM)
# Docker ichidan host mashinaga ulanish uchun host.docker.internal ishlatiladi
# Linux da docker run --add-host=host.docker.internal:host-gateway kerak bo'lishi mumkin
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
# AI ni o'chirish uchun false qiling
AI_ENABLED=true

# Log darajasi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
TZ=Asia/Tashkent
